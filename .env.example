# All values are validated at boot by env.server.ts. Missing or invalid
# values cause the server/worker to fail fast on startup.

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-random-string-at-least-32-characters-long
REFRESH_SECRET=replace-with-a-different-random-string-at-least-32-chars

DATABASE_URL=postgresql://blueprint-user:blueprint-password@127.0.0.1:55432/blueprint
REDIS_URL=redis://localhost:6379

LETTERMINT_API_KEY=your-lettermint-api-key
MAIL_FROM=YourApp <noreply@yourdomain.com>
APP_URL=http://localhost:5173
